# Server
PORT=3000
JWT_SECRET=7f3a9d2e1b6c4f8a9d0e3b7c2f1a8d5e
JWT_EXPIRES_IN=7d

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
