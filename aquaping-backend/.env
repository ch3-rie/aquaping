# Twilio (or adapter)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM=+1234567890

# App settings
SEV_THRESHOLD_YELLOW=30
SEV_THRESHOLD_ORANGE=70
